"Calculates how the object should face the camera to be applied on Model View "
"Matrix output port for 3D objects."
msgstr ""
"Tính toán hướng xoay đối diện camera của vật thể 3D để áp dụng trực tiếp vào "
"cổng đầu ra của Ma trận Model View."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Calculates the inverse of a transform."
msgstr "Tính nghịch đảo của phép biến đổi."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Calculates the transpose of a transform."
msgstr "Tính chuyển vị của phép biến đổi."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
