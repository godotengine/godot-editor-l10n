msgstr "Áp dụng hàm dịch chuyển cuộn ảnh (panning) lên hệ tọa độ kết cấu."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Apply scaling function on texture coordinates."
msgstr "Áp dụng hàm co giãn tỷ lệ (scaling) lên hệ tọa độ kết cấu."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Cubic texture parameter lookup."
msgstr "Tra cứu tham số kết cấu nội suy bậc ba."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "2D texture parameter lookup."
msgstr "Tra cứu tham số kết cấu 2D."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "2D texture parameter lookup with triplanar."
msgstr ""
"Tra cứu tham số kết cấu 2D kết hợp phép chiếu ba mặt phẳng (triplanar)."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
