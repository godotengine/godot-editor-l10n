msgstr "Không thể đọc tệp tin: \"%s\"."

#: platform/web/export/export_plugin.cpp
msgid "PWA"
msgstr "PWA"

#: platform/web/export/export_plugin.cpp
msgid ""
"Exporting to Web is currently not supported in Godot 4 when using C#/.NET. "
"Use Godot 3 to target Web with C#/Mono instead."
msgstr ""
"Việc xuất ra Web hiện chưa được hỗ trợ trong Godot 4 khi dùng C#/.NET. Hãy "
"sử dụng Godot 3 nếu muốn xuất Web với C#/Mono."

#: platform/web/export/export_plugin.cpp
msgid ""
"If this project does not use C#, use a non-C# editor build to export the "
"project."
msgstr ""
"Nếu dự án này không dùng C#, hãy sử dụng bản Godot không kèm C# để xuất dự "
"án."

#: platform/web/export/export_plugin.cpp
msgid "Could not read HTML shell: \"%s\"."
msgstr "Không thể đọc được HTML shell: \"%s\"."

#: platform/web/export/export_plugin.cpp
msgid "Run in Browser"
msgstr "Chạy trong Trình duyệt web"

#: platform/web/export/export_plugin.cpp
msgid "Start HTTP Server"
msgstr "Khởi động Máy chủ HTTP"

#: platform/web/export/export_plugin.cpp
msgid "Re-export Project"
msgstr "Xuất lại Dự án"

#: platform/web/export/export_plugin.cpp
msgid "Stop HTTP Server"
msgstr "Dừng Máy chủ HTTP"

#: platform/web/export/export_plugin.cpp
msgid "Run exported HTML in the system's default browser."
msgstr "Chạy HTML được xuất với trình duyệt mặc định của máy."

#: platform/web/export/export_plugin.cpp
msgid "Start the HTTP server."
msgstr "Khởi động máy chủ HTTP."

#: platform/web/export/export_plugin.cpp
msgid "Export project again to account for updates."
msgstr "Hãy xuất lại dự án để cập nhật những thay đổi mới."

#: platform/web/export/export_plugin.cpp
msgid "Stop the HTTP server."
msgstr "Dừng máy chủ HTTP."

#: platform/web/export/export_plugin.cpp
msgid "Could not create HTTP server directory: %s."
msgstr "Không thể tạo thư mục máy chủ HTTP: %s."

#: platform/web/export/export_plugin.cpp
msgid "Error starting HTTP server: %d."
msgstr "Lỗi khi khởi động máy chủ HTTP: %d."

#: platform/windows/export/export_plugin.cpp
msgid "Resources Modification"
msgstr "Sửa đổi Tài nguyên"

#: platform/windows/export/export_plugin.cpp
msgid "Icon size \"%d\" is missing."
msgstr "Thiếu kích cỡ biểu tượng \"%d\"."

#: platform/windows/export/export_plugin.cpp
msgid "Failed to rename temporary file \"%s\"."
msgstr "Không thể đổi tên tệp tin tạm thời \"%s\"."

#: platform/windows/export/export_plugin.cpp
msgid "Invalid icon path."
msgstr "Đường dẫn biểu tượng không hợp lệ."

#: platform/windows/export/export_plugin.cpp
msgid "Invalid file version."
msgstr "Phiên bản tệp không hợp lệ."

#: platform/windows/export/export_plugin.cpp
msgid "Invalid product version."
msgstr "Phiên bản sản phẩm không hợp lệ."

#: platform/windows/export/export_plugin.cpp
msgid "Invalid icon file \"%s\"."
msgstr "Tệp tin biểu tượng \"%s\" không hợp lệ."

#: platform/windows/export/export_plugin.cpp
msgid "Could not find signtool executable at \"%s\"."
msgstr "Không thể tìm thấy tệp tin thực thi signtool tại \"%s\"."

#: platform/windows/export/export_plugin.cpp
msgid "Could not find osslsigncode executable at \"%s\"."
msgstr "Không thể tìm thấy tệp tin thực thi osslsigncode tại \"%s\"."

#: platform/windows/export/export_plugin.cpp
msgid "No identity found."
msgstr "Không tìm thấy danh tính (identity)."

#: platform/windows/export/export_plugin.cpp
msgid "Invalid identity type."
msgstr "Loại danh tính không hợp lệ."

#: platform/windows/export/export_plugin.cpp
msgid "Invalid timestamp server."
msgstr "Máy chủ dấu thời gian không hợp lệ."

#: platform/windows/export/export_plugin.cpp
msgid ""
"Could not start signtool executable. Configure signtool path in the Editor "
"Settings (Export > Windows > signtool), or disable \"Codesign\" in the "
"export preset."
msgstr ""
"Không thể khởi chạy tệp thực thi signtool. Hãy cấu hình đường dẫn signtool "
"trong Cài đặt Trình biên tập (Export > Windows > signtool), hoặc tắt "
"\"Codesign\" trong cài đặt xuất."

#: platform/windows/export/export_plugin.cpp
msgid ""
"Could not start osslsigncode executable. Configure signtool path in the "
"Editor Settings (Export > Windows > osslsigncode), or disable \"Codesign\" "
"in the export preset."
msgstr ""
"Không thể khởi chạy tệp thực thi osslsigncode. Hãy cấu hình đường dẫn trong "
"Cài đặt Trình biên tập (Export > Windows > osslsigncode), hoặc tắt "
"\"Codesign\" trong cài đặt xuất."

#: platform/windows/export/export_plugin.cpp
msgid "Signtool failed to sign executable: %s."
msgstr "Signtool thất bại khi khí tệp tin thực thi: %s."

#: platform/windows/export/export_plugin.cpp
msgid "Failed to remove temporary file \"%s\"."
msgstr "Không thể gỡ bỏ tệp tạm thời \"%s\"."

#: platform/windows/export/export_plugin.cpp
msgid "Windows executables cannot be >= 4 GiB."
msgstr "Các tệp thực thi Windows không được phép >= 4 GiB."

#: platform/windows/export/export_plugin.cpp
msgid "Run on remote Windows system"
msgstr "Chạy trên hệ thống Windows từ xa"

#: platform/windows/export/export_plugin.cpp
msgid "Run exported project on remote Windows system"
msgstr "Chạy dự án đã xuất trên hệ thống Windows từ xa"

#: scene/2d/animated_sprite_2d.cpp
msgid ""
"A SpriteFrames resource must be created or set in the \"Sprite Frames\" "
"property in order for AnimatedSprite2D to display frames."
msgstr ""
"Tài nguyên SpriteFrames phải được tạo hoặc thiết lập trong thuộc tính "
"\"Sprite Frames\" để AnimatedSprite2D hiển thị khung hình."

#: scene/2d/canvas_group.cpp
msgid ""
"Ancestor \"%s\" clips its children, so this CanvasGroup will not function "
"properly."
msgstr ""
"Nút cha/tổ tiên \"%s\" thực hiện cắt (clip) các nút con, do đó CanvasGroup "
"này sẽ không hoạt động đúng cách."

#: scene/2d/canvas_group.cpp
msgid ""
"Ancestor \"%s\" is a CanvasGroup, so this CanvasGroup will not function "
"properly."
msgstr ""
"Nút cha/tổ tiên \"%s\" cũng là một CanvasGroup, do đó CanvasGroup này sẽ "
"không hoạt động đúng cách."

#: scene/2d/canvas_modulate.cpp
msgid ""
"Only one visible CanvasModulate is allowed per canvas.\n"
"When there are more than one, only one of them will be active. Which one is "
"undefined."
msgstr ""
"Chỉ cho phép một CanvasModulate không bị ẩn ứng với một cảnh vẽ.\n"
"Khi có nhiểu hơn một cái, chỉ một trong số chúng sẽ hoạt động. Những cái còn "
"lại sẽ được coi là không xác định."

#: scene/2d/cpu_particles_2d.cpp
msgid ""
"CPUParticles2D animation requires the usage of a CanvasItemMaterial with "
"\"Particles Animation\" enabled."
msgstr ""
"Hoạt ảnh CPUParticles2D cần CanvasItemMaterial bật \"Particles Animation\"."

#: scene/2d/gpu_particles_2d.cpp scene/3d/gpu_particles_3d.cpp
msgid ""
"A material to process the particles is not assigned, so no behavior is "
"imprinted."
msgstr ""
"Chưa chỉ định vật liệu xử lý các hạt (particle), vì vậy hạt sẽ không có hành "
"vi cụ thể."

#: scene/2d/gpu_particles_2d.cpp
msgid ""
"Particles2D animation requires the usage of a CanvasItemMaterial with "
"\"Particles Animation\" enabled."
msgstr ""
"Hoạt ảnh Particles2D cần CanvasItemMaterial bật \"Particles Animation\"."

#: scene/2d/gpu_particles_2d.cpp scene/3d/gpu_particles_3d.cpp
msgid ""
"Particle trails are only available when using the Forward+ or Mobile "
"renderer."
msgstr ""
"Đường dẫn hạt chỉ khả dụng khi sử dụng trình kết xuất Forward+ hoặc Mobile."

#: scene/2d/gpu_particles_2d.cpp
msgid ""
"Particle sub-emitters are not available when using the Compatibility "
"renderer."
msgstr ""
"Bộ phát hạt phụ không khả dụng khi sử dụng trình kết xuất Compatibility."

#: scene/2d/light_2d.cpp
msgid ""
"A texture with the shape of the light must be supplied to the \"Texture\" "
"property."
msgstr ""
"Phải cung cấp một kết cấu hình dạng ánh sáng cho thuộc tính \"Texture\"."

#: scene/2d/light_occluder_2d.cpp
msgid ""
"An occluder polygon must be set (or drawn) for this occluder to take effect."
msgstr ""
"Phải thiết lập (hoặc vẽ) một đa giác che chắn (occluder polygon) để nút này "
"có hiệu lực."

#: scene/2d/light_occluder_2d.cpp
msgid "The occluder polygon for this occluder is empty. Please draw a polygon."
msgstr "Đa giác che chắn đang trống. Vui lòng vẽ một đa giác."

#: scene/2d/mesh_instance_2d.cpp
msgid ""
"MeshInstance2D requires a Mesh to render anything. Please add a mesh "
"resource for it!"
msgstr ""
"MeshInstance2D cần một Mesh để hiển thị. Vui lòng thêm tài nguyên mesh cho "
"nó!"

#: scene/2d/navigation/navigation_agent_2d.cpp
msgid ""
"The NavigationAgent2D can be used only under a Node2D inheriting parent node."
msgstr ""
"NavigationAgent2D chỉ có thể được sử dụng bên dưới một node cha kế thừa từ "
"Node2D."

#: scene/2d/navigation/navigation_link_2d.cpp
msgid ""
"NavigationLink2D start position should be different than the end position to "
"be useful."
msgstr ""
"Vị trí bắt đầu và kết thúc của NavigationLink2D phải khác nhau thì mới có "
"tác dụng."

#: scene/2d/navigation/navigation_obstacle_2d.cpp
msgid "NavigationObstacle2D does not support negative or zero scaling."
msgstr "NavigationObstacle2D không hỗ trợ tỉ lệ âm hoặc bằng 0."

#: scene/2d/navigation/navigation_obstacle_2d.cpp
msgid ""
"The agent radius can only be scaled uniformly. The largest value along the "
"two axes of the global scale will be used to scale the radius. This value "
"may change in unexpected ways when the node is rotated."
msgstr ""
"Bán kính tác nhân chỉ có thể được co giãn đồng đều. Giá trị lớn nhất dọc "
"theo hai trục của tỉ lệ toàn cục sẽ được dùng để co giãn bán kính. Giá trị "
"này có thể thay đổi bất ngờ khi node bị xoay."

#: scene/2d/navigation/navigation_obstacle_2d.cpp
msgid "Skew has no effect on the agent radius."
msgstr "Độ nghiêng (Skew) không có tác dụng với bán kính tác nhân."

#: scene/2d/navigation/navigation_region_2d.cpp
msgid ""
"A NavigationPolygon resource must be set or created for this node to work. "
"Please set a property or draw a polygon."
msgstr ""
"Phải thiết lập hoặc tạo tài nguyên NavigationPolygon để node này hoạt động. "
"Vui lòng thiết lập thuộc tính hoặc vẽ đa giác."

#: scene/2d/parallax_layer.cpp
msgid ""
"ParallaxLayer node only works when set as child of a ParallaxBackground node."
msgstr ""
"Nút ParallaxLayer chỉ hoạt động khi là con của một nút ParallaxBackground."

#: scene/2d/path_2d.cpp
msgid "PathFollow2D only works when set as a child of a Path2D node."
msgstr "PathFollow2D chỉ hoạt động khi được đặt làm con của một nút Path2D."

#: scene/2d/physics/collision_object_2d.cpp
msgid ""
"This node has no shape, so it can't collide or interact with other objects.\n"
"Consider adding a CollisionShape2D or CollisionPolygon2D as a child to "
"define its shape."
msgstr ""
"Nút này không có hình thù, nên không thể va chạm hoặc tương tác với các vật "
"khác.\n"
"Hãy thêm nút con CollisionShape2D hoặc CollisionPolygon2D để định dạng cho "
"nút này."

#: scene/2d/physics/collision_polygon_2d.cpp
msgid ""
"CollisionPolygon2D only serves to provide a collision shape to a "
"CollisionObject2D derived node. Please only use it as a child of Area2D, "
"StaticBody2D, RigidBody2D, CharacterBody2D, etc. to give them a shape."
msgstr ""
"CollisionPolygon2D chỉ dùng để cung cấp hình dạng va chạm cho các node kế "
"thừa từ CollisionObject2D. Vui lòng chỉ sử dụng nó làm con của Area2D, "
"StaticBody2D, RigidBody2D, CharacterBody2D, v.v. để định hình cho chúng."

#: scene/2d/physics/collision_polygon_2d.cpp
msgid "An empty CollisionPolygon2D has no effect on collision."
msgstr "ColiisionPolygon2D rỗng sẽ không phản ứng gì khi có va chạm."

#: scene/2d/physics/collision_polygon_2d.cpp
msgid "Invalid polygon. At least 3 points are needed in 'Solids' build mode."
msgstr "Đa giác không hợp lệ. Cần ít nhất 3 điểm trong chế độ dựng \"Solids\"."

#: scene/2d/physics/collision_polygon_2d.cpp
msgid "Invalid polygon. At least 2 points are needed in 'Segments' build mode."
msgstr "Đa giác không hợp lệ. Cần ít nhất 2 điểm trong chế độ dựng 'Segments'."

#: scene/2d/physics/collision_polygon_2d.cpp
#: scene/2d/physics/collision_shape_2d.cpp
msgid ""
"The One Way Collision property will be ignored when the collision object is "
"an Area2D."
msgstr ""
"Thuộc tính Va chạm Một chiều (One Way Collision) sẽ bị bỏ qua khi đối tượng "
"va chạm là Area2D."

#: scene/2d/physics/collision_shape_2d.cpp
msgid ""
"CollisionShape2D only serves to provide a collision shape to a "
"CollisionObject2D derived node.\n"
"Please only use it as a child of Area2D, StaticBody2D, RigidBody2D, "
"CharacterBody2D, etc. to give them a shape."
msgstr ""
"CollisionShape2D chỉ có mục đích là cung cấp hình dạng va chạm cho một Nút "
"CollisionObject2D.\n"
"Cho nên hãy dùng nó như là nút con của Area2D, StaticBody2D, RigidBody2D, "
"v.v để thêm hình dạng cho chúng."

#: scene/2d/physics/collision_shape_2d.cpp
msgid ""
"A shape must be provided for CollisionShape2D to function. Please create a "
"shape resource for it!"
msgstr ""
"CollisionShape2D cần một khối hình mới hoạt động được. Hãy tạo một tài "
"nguyên khối hình cho nó!"

#: scene/2d/physics/collision_shape_2d.cpp
msgid ""
"The CollisionShape2D node has limited editing options for polygon-based "
"shapes. Consider using a CollisionPolygon2D node instead."
msgstr ""
"Node CollisionShape2D có tùy chọn chỉnh sửa hạn chế cho các hình dạng dựa "
"trên đa giác. Hãy cân nhắc sử dụng CollisionPolygon2D thay thế."

#: scene/2d/physics/joints/joint_2d.cpp
msgid "Node A and Node B must be PhysicsBody2Ds"
msgstr "Nút A và Nút B phải là PhysicsBody2D"

#: scene/2d/physics/joints/joint_2d.cpp
msgid "Node A must be a PhysicsBody2D"
msgstr "Nút A phải là PhysicsBody2D"

#: scene/2d/physics/joints/joint_2d.cpp
msgid "Node B must be a PhysicsBody2D"
msgstr "Nút B phải là PhysicsBody2D"

#: scene/2d/physics/joints/joint_2d.cpp
msgid "Joint is not connected to two PhysicsBody2Ds"
msgstr "Khớp nối chưa kết nối tới hai PhysicsBody2D"

#: scene/2d/physics/joints/joint_2d.cpp
msgid "Node A and Node B must be different PhysicsBody2Ds"
msgstr "Nút A và Nút B phải là 2 PhysicsBody2D khác nhau"

#: scene/2d/physics/physical_bone_2d.cpp
msgid ""
"A PhysicalBone2D only works with a Skeleton2D or another PhysicalBone2D as a "
"parent node!"
msgstr ""
"PhysicalBone2D chỉ hoạt động khi node cha là Skeleton2D hoặc một "
"PhysicalBone2D khác!"

#: scene/2d/physics/physical_bone_2d.cpp
msgid ""
"A PhysicalBone2D needs to be assigned to a Bone2D node in order to function! "
"Please set a Bone2D node in the inspector."
msgstr ""
"PhysicalBone2D cần được gán vào một Bone2D node mới có thể hoạt động! Vui "
"lòng chỉ định một Bone2D node trong inspector."

#: scene/2d/physics/physical_bone_2d.cpp
msgid ""
"A PhysicalBone2D node should have a Joint2D-based child node to keep bones "
"connected! Please add a Joint2D-based node as a child to this node!"
msgstr ""
"PhysicalBone2D nên có một node con dựa trên Joint2D để giữ kết nối giữa các "
"xương! Vui lòng thêm một node con là Joint2D cho node này!"

#: scene/2d/physics/physics_body_2d.cpp
msgid ""
"PhysicsBody2D will not work correctly on a non-interpolated branch of the "
"SceneTree.\n"
"Check the node's inherited physics_interpolation_mode."
msgstr ""
"PhysicsBody2D sẽ không hoạt động đúng trên nhánh không nội suy của "
"SceneTree.\n"
"Kiểm tra lại thuộc tính physics_interpolation_mode của node."

#: scene/2d/physics/rigid_body_2d.cpp
msgid ""
"Size changes to RigidBody2D will be overridden by the physics engine when "
"running.\n"
"Change the size in children collision shapes instead."
msgstr ""
"Thay đổi kích thước đối với RigidBody2D sẽ bị ghi đè bởi công cụ vật lý khi "
"đang chạy.\n"
"Hãy thay đổi kích thước trong các hình dạng va chạm con."

#: scene/2d/physics/shape_cast_2d.cpp
msgid ""
"This node cannot interact with other objects unless a Shape2D is assigned."
msgstr ""
"Node này không thể tương tác với các đối tượng khác trừ khi được gán Shape2D."

#: scene/2d/remote_transform_2d.cpp
msgid "Path property must point to a valid Node2D node to work."
msgstr ""
"Thuộc tính Đường dẫn phải chỉ đến một nút Node2D hợp lệ thì mới hoạt động "
"được."

#: scene/2d/skeleton_2d.cpp
msgid "This Bone2D chain should end at a Skeleton2D node."
msgstr "Chuỗi Bone2D này phải kết thúc với một nút Skeleton2D."

#: scene/2d/skeleton_2d.cpp
msgid "A Bone2D only works with a Skeleton2D or another Bone2D as parent node."
msgstr ""
"Bone2D chỉ hoạt động khi là con một nút Skeleton2D hoặc một Bone2D khác ."

#: scene/2d/skeleton_2d.cpp
msgid ""
"This bone lacks a proper REST pose. Go to the Skeleton2D node and set one."
msgstr ""
"Xương này thiếu tư thế REST hợp lệ. Hãy đi tới node Skeleton2D và thiết lập "
"một tư thế."

#: scene/2d/tile_map.cpp
msgid ""
"The TileMap node is deprecated as it is superseded by the use of multiple "
"TileMapLayer nodes.\n"
"To convert a TileMap to a set of TileMapLayer nodes, open the TileMap bottom "
"panel with this node selected, click the toolbox icon in the top-right "
"corner and choose \"Extract TileMap layers as individual TileMapLayer "
"nodes\"."
msgstr ""
"TileMap node đã lỗi thời và được thay thế bằng việc sử dụng nhiều "
"TileMapLayer node.\n"
"Để chuyển đổi TileMap sang TileMapLayer, hãy mở bảng điều khiển TileMap phía "
"dưới, chọn biểu tượng hộp công cụ ở góc trên bên phải và chọn \"Extract "
"TileMap layers as individual TileMapLayer nodes\"."

#: scene/2d/tile_map.cpp
msgid ""
"A Y-sorted layer has the same Z-index value as a not Y-sorted layer.\n"
"This may lead to unwanted behaviors, as a layer that is not Y-sorted will be "
"Y-sorted as a whole with tiles from Y-sorted layers."
msgstr ""
"Một lớp có Y-sort có cùng Z-index với một lớp không có Y-sort.\n"
"Điều này có thể gây ra lỗi hiển thị, vì lớp không có Y-sort sẽ bị coi là Y-"
"sort toàn bộ cùng với các tile từ lớp có Y-sort."

#: scene/2d/tile_map.cpp
msgid ""
"A TileMap layer is set as Y-sorted, but Y-sort is not enabled on the TileMap "
"node itself."
msgstr ""
"Một lớp TileMap được đặt là Y-sorted, nhưng tính năng Y-sort chưa được bật "
"trên chính TileMap node."

#: scene/2d/tile_map.cpp
msgid ""
"The TileMap node is set as Y-sorted, but Y-sort is not enabled on any of the "
"TileMap's layers.\n"
"This may lead to unwanted behaviors, as a layer that is not Y-sorted will be "
"Y-sorted as a whole."
msgstr ""
"TileMap node được đặt là Y-sorted, nhưng chưa có lớp nào của TileMap được "
"bật Y-sort.\n"
"Điều này có thể gây ra lỗi hiển thị không mong muốn."

#: scene/2d/tile_map.cpp
msgid ""
"Isometric TileSet will likely not look as intended without Y-sort enabled "
"for the TileMap and all of its layers."
msgstr ""
"Isometric TileSet có thể sẽ không hiển thị đúng nếu không bật Y-sort cho cả "
"TileMap và tất cả các lớp của nó."

#: scene/3d/aim_modifier_3d.cpp
msgid ""
"Forward axis and primary rotation axis must not be parallel in setting %s."
msgstr ""
"Trục tiến (Forward axis) và trục xoay chính không được song song trong cài "
"đặt %s."

#: scene/3d/bone_attachment_3d.cpp
msgid ""
"External Skeleton3D node not set! Please set a path to an external "
"Skeleton3D node."
msgstr ""
"Chưa thiết lập node Skeleton3D bên ngoài! Vui lòng cung cấp đường dẫn tới "
"một node Skeleton3D."

#: scene/3d/bone_attachment_3d.cpp
msgid ""
"Parent node is not a Skeleton3D node! Please use an external Skeleton3D if "
"you intend to use the BoneAttachment3D without it being a child of a "
"Skeleton3D node."
msgstr ""
"Node cha không phải là Skeleton3D! Vui lòng sử dụng Skeleton3D bên ngoài nếu "
"bạn muốn sử dụng BoneAttachment3D mà không đặt nó làm con của Skeleton3D."

#: scene/3d/bone_attachment_3d.cpp
msgid ""
"BoneAttachment3D node is not bound to any bones! Please select a bone to "
"attach this node."
msgstr ""
"Node BoneAttachment3D chưa được gắn vào xương nào! Vui lòng chọn một xương "
"để đính kèm node này."

#: scene/3d/cpu_particles_3d.cpp
msgid "Nothing is visible because no mesh has been assigned."
msgstr "Không có gì hiển thị vì không có lưới nào được chỉ định."

#: scene/3d/cpu_particles_3d.cpp
msgid ""
"CPUParticles3D animation requires the usage of a StandardMaterial3D whose "
"Billboard Mode is set to \"Particle Billboard\"."
msgstr ""
"Hoạt ảnh CPUParticles3D yêu cầu sử dụng StandardMaterial3D với Chế độ "
"Billboard được đặt là \"Particle Billboard\"."

#: scene/3d/decal.cpp
msgid "Decals are only available when using the Forward+ or Mobile renderer."
msgstr "Decal chỉ khả dụng khi sử dụng trình kết xuất Forward+ hoặc Mobile."

#: scene/3d/decal.cpp
msgid ""
"The decal has no textures loaded into any of its texture properties, and "
"will therefore not be visible."
msgstr ""
"Decal chưa được tải kết cấu vào bất kỳ thuộc tính nào, do đó nó sẽ không "
"hiển thị."

#: scene/3d/decal.cpp
msgid ""
"The decal has a Normal and/or ORM texture, but no Albedo texture is set.\n"
"An Albedo texture with an alpha channel is required to blend the normal/ORM "
"maps onto the underlying surface.\n"
"If you don't want the Albedo texture to be visible, set Albedo Mix to 0."
msgstr ""
"Decal có kết cấu Normal và/hoặc ORM nhưng chưa có kết cấu Albedo.\n"
"Cần có một kết cấu Albedo với kênh alpha để hòa trộn các bản đồ normal/ORM "
"lên bề mặt bên dưới.\n"
"Nếu bạn không muốn kết cấu Albedo hiển thị, hãy đặt Albedo Mix bằng 0."

#: scene/3d/decal.cpp
msgid ""
"The decal's Cull Mask has no bits enabled, which means the decal will not "
"paint objects on any layer.\n"
"To resolve this, enable at least one bit in the Cull Mask property."
msgstr ""
"Cull Mask của decal chưa được bật bit nào, nghĩa là decal sẽ không vẽ lên "
"đối tượng nào ở bất kỳ lớp nào.\n"
"Để khắc phục, hãy bật ít nhất một bit trong thuộc tính Cull Mask."

#: scene/3d/fog_volume.cpp
msgid "Fog Volumes are only visible when using the Forward+ renderer."
msgstr ""
"Khối sương mù (Fog Volumes) chỉ hiển thị khi sử dụng trình kết xuất Forward+."

#: scene/3d/fog_volume.cpp
msgid ""
"Fog Volumes need volumetric fog to be enabled in the scene's Environment in "
"order to be visible."
msgstr ""
"Fog Volume cần phải bật sương mù thể tích (volumetric fog) trong phần "
"Environment của scene mới có thể hiển thị được."

#: scene/3d/gpu_particles_3d.cpp
msgid ""
"Nothing is visible because meshes have not been assigned to draw passes."
msgstr "Không có gì hiển thị vì meshes chưa được gán vào các draw passes."

#: scene/3d/gpu_particles_3d.cpp
msgid ""
"Particles animation requires the usage of a BaseMaterial3D whose Billboard "
"Mode is set to \"Particle Billboard\"."
msgstr ""
"Hoạt ảnh hạt yêu cầu sử dụng BaseMaterial3D với Chế độ Billboard được đặt là "
"\"Particle Billboard\"."

#: scene/3d/gpu_particles_3d.cpp
msgid ""
"Using Trail meshes with a skin causes Skin to override Trail poses. Suggest "
"removing the Skin."
msgstr ""
"Sử dụng Trail meshes kèm với skin sẽ khiến Skin ghi đè lên các tư thế của "
"Trail. Khuyên nên xóa Skin đi."

#: scene/3d/gpu_particles_3d.cpp
msgid "Trails active, but neither Trail meshes or a Skin were found."
msgstr "Trails đang hoạt động nhưng không tìm thấy Trail meshes hoặc Skin."

#: scene/3d/gpu_particles_3d.cpp
msgid ""
"Only one Trail mesh is supported. If you want to use more than a single "
"mesh, a Skin is needed (see documentation)."
msgstr ""
"Chỉ hỗ trợ một Trail mesh duy nhất. Nếu bạn muốn sử dụng nhiều mesh, cần "
"phải có Skin (xem tài liệu)."

#: scene/3d/gpu_particles_3d.cpp
msgid ""
"Trails enabled, but one or more mesh materials are either missing or not set "
"for trails rendering."
msgstr ""
"Trails đã bật nhưng một hoặc nhiều vật liệu mesh bị thiếu hoặc chưa được "
"thiết lập để kết xuất."

#: scene/3d/gpu_particles_3d.cpp
msgid ""
"Particle sub-emitters are only available when using the Forward+ or Mobile "
"renderer."
msgstr ""
"Bộ phát hạt phụ chỉ khả dụng khi sử dụng trình kết xuất Forward+ hoặc Mobile."

#: scene/3d/gpu_particles_collision_3d.cpp
msgid ""
"The Bake Mask has no bits enabled, which means baking will not produce any "
"collision for this GPUParticlesCollisionSDF3D.\n"
"To resolve this, enable at least one bit in the Bake Mask property."
msgstr ""
"Bake Mask chưa bật bit nào, nghĩa là quá trình nướng (baking) sẽ không tạo "
"ra va chạm cho GPUParticlesCollisionSDF3D này.\n"
"Để khắc phục, hãy bật ít nhất một bit trong thuộc tính Bake Mask."

#: scene/3d/iterate_ik_3d.cpp
msgid ""
"Detecting settings with no target set! IterateIK3D must have a target to "
"work."
msgstr ""
"Chưa thiết lập đích (target)! IterateIK3D cần phải có đích mới hoạt động "
"được."

#: scene/3d/light_3d.cpp
msgid "A light's scale does not affect the visual size of the light."
msgstr "Tỉ lệ (scale) của đèn không ảnh hưởng đến kích thước hiển thị của đèn."

#: scene/3d/light_3d.cpp
msgid "Projector texture only works with shadows active."
msgstr "Kết cấu máy chiếu (projector texture) chỉ hoạt động khi bật đổ bóng."

#: scene/3d/light_3d.cpp
msgid ""
"Projector textures are not supported when using the Compatibility renderer "
"yet. Support will be added in a future release."
msgstr ""
"Kết cấu máy chiếu chưa được hỗ trợ khi dùng trình kết xuất Compatibility. Hỗ "
"trợ sẽ được thêm trong bản cập nhật tương lai."

#: scene/3d/light_3d.cpp
msgid "A SpotLight3D with an angle wider than 90 degrees cannot cast shadows."
msgstr "SpotLight3D với góc chiếu lớn hơn 90 độ không thể đổ bóng."

#: scene/3d/light_3d.cpp
msgid ""
"Projector texture is not supported for area lights. Use the area_texture "
"field instead."
msgstr ""
"Kết cấu máy chiếu không được hỗ trợ cho đèn khu vực (area lights). Hãy sử "
"dụng trường area_texture thay thế."

#: scene/3d/light_3d.cpp
msgid ""
"Rendering textured area lights is not implemented in the Compatibility "
"rendering mode."
msgstr ""
"Việc kết xuất đèn khu vực có kết cấu chưa được triển khai trong chế độ kết "
"xuất Compatibility."

#: scene/3d/light_3d.cpp
msgid ""
"Rendering area light shadows does not work in the Compatibility rendering "
"mode."
msgstr ""
"Kết xuất đổ bóng đèn khu vực không hoạt động trong chế độ kết xuất "
"Compatibility."

#: scene/3d/lightmap_gi.cpp
msgid "Finding meshes, lights and probes"
msgstr "Đang tìm meshes, đèn và probes"

#: scene/3d/lightmap_gi.cpp
msgid "Preparing geometry %d/%d"
msgstr "Đang xử lí hình học %d/%d"

#: scene/3d/lightmap_gi.cpp
msgid "Creating probes"
msgstr "Đang tạo probes"

#: scene/3d/lightmap_gi.cpp
msgid "Creating probes from mesh %d/%d"
msgstr "Đang tạo probes từ mesh %d/%d"

#: scene/3d/lightmap_gi.cpp
msgid "Preparing Lightmapper"
msgstr "Đang chuẩn bị Lightmapper"

#: scene/3d/lightmap_gi.cpp
msgid "Preparing Environment"
msgstr "Đang chuẩn bị Môi trường"

#: scene/3d/lightmap_gi.cpp
msgid "Generating Probe Volumes"
msgstr "Tạo Probe Volumes"

#: scene/3d/lightmap_gi.cpp
msgid "Generating Probe Acceleration Structures"
msgstr "Đang tạo cấu trúc tăng tốc Probe"

#: scene/3d/lightmap_gi.cpp
msgid ""
"Lightmaps can only be baked from a GPU that supports the RenderingDevice "
"backends.\n"
"Your GPU (%s) does not support RenderingDevice, as it does not support "
"Vulkan, Direct3D 12, or Metal.\n"
"Lightmap baking will not be available on this device, although rendering "
"existing baked lightmaps will work."
msgstr ""
"Lightmaps chỉ có thể được nướng từ GPU hỗ trợ backend RenderingDevice.\n"
"GPU của bạn (%s) không hỗ trợ RenderingDevice do không hỗ trợ Vulkan, "
"Direct3D 12 hoặc Metal.\n"
"Tính năng nướng Lightmap sẽ không khả dụng, tuy nhiên việc hiển thị các "
"lightmap đã nướng sẵn vẫn hoạt động."

#: scene/3d/lightmap_gi.cpp
msgid ""
"The lightmap has no baked shadowmask textures. Please rebake with the "
"Shadowmask Mode set to anything other than None."
msgstr ""
"Lightmap chưa có kết cấu shadowmask. Vui lòng nướng lại với Shadowmask Mode "
"khác None."

#: scene/3d/lightmap_gi.cpp
msgid ""
"Lightmaps cannot be baked on %s. Rendering existing baked lightmaps will "
"still work."
msgstr ""
"Không thể nướng lightmap trên %s. Việc hiển thị các lightmap đã nướng sẵn "
"vẫn hoạt động."

#: scene/3d/lightmap_gi.cpp
msgid ""
"Lightmaps cannot be baked, as the `lightmapper_rd` module was disabled at "
"compile-time. Rendering existing baked lightmaps will still work."
msgstr ""
"Không thể nướng lightmap do module `lightmapper_rd` bị tắt khi biên dịch. "
"Việc hiển thị các lightmap đã nướng sẵn vẫn hoạt động."

#: scene/3d/look_at_modifier_3d.cpp
msgid "Forward axis and primary rotation axis must not be parallel."
msgstr "Trục tiến (Forward axis) và trục xoay chính không được song song."

#: scene/3d/mesh_instance_3d.cpp
msgid ""
"MeshInstance3D requires a Mesh to render anything. Please add a mesh "
"resource for it!"
msgstr ""
"MeshInstance3D cần một Mesh để hiển thị. Vui lòng thêm tài nguyên mesh cho "
"nó!"

#: scene/3d/navigation/navigation_agent_3d.cpp
msgid ""
"The NavigationAgent3D can be used only under a Node3D inheriting parent node."
msgstr ""
"NavigationAgent3D chỉ có thể được sử dụng bên dưới một node cha kế thừa từ "
"Node3D."

#: scene/3d/navigation/navigation_link_3d.cpp
msgid ""
"NavigationLink3D start position should be different than the end position to "
"be useful."
msgstr ""
"Vị trí bắt đầu và kết thúc của NavigationLink3D phải khác nhau thì mới có "
"tác dụng."

#: scene/3d/navigation/navigation_obstacle_3d.cpp
msgid ""
"NavigationObstacle3D only takes global rotation around the y-axis into "
"account. Rotations around the x-axis or z-axis might lead to unexpected "
"results."
msgstr ""
"NavigationObstacle3D chỉ tính đến xoay toàn cục quanh trục Y. Xoay quanh "
"trục X hoặc Z có thể dẫn đến kết quả không mong muốn."

#: scene/3d/navigation/navigation_obstacle_3d.cpp
msgid "NavigationObstacle3D does not support negative or zero scaling."
msgstr "NavigationObstacle3D không hỗ trợ tỉ lệ âm hoặc bằng 0."

#: scene/3d/navigation/navigation_obstacle_3d.cpp
msgid ""
"The agent radius can only be scaled uniformly. The largest scale value along "
"the three axes will be used."
msgstr ""
"Bán kính tác nhân chỉ có thể được co giãn đồng đều. Giá trị tỉ lệ lớn nhất "
"dọc theo ba trục sẽ được sử dụng."

#: scene/3d/occluder_instance_3d.cpp
msgid ""
"Occlusion culling is disabled in the Project Settings, which means occlusion "
"culling won't be performed in the root viewport.\n"
"To resolve this, open the Project Settings and enable Rendering > Occlusion "
"Culling > Use Occlusion Culling."
msgstr ""
"Tính năng occlusion culling (cắt tỉa vật bị che khuất) đang bị tắt trong Cài "
"đặt Dự án, nghĩa là nó sẽ không được thực hiện trong root viewport.\n"
"Để khắc phục, hãy mở Cài đặt Dự án và bật Rendering > Occlusion Culling > "
"Use Occlusion Culling."

#: scene/3d/occluder_instance_3d.cpp
msgid ""
"The Bake Mask has no bits enabled, which means baking will not produce any "
"occluder meshes for this OccluderInstance3D.\n"
"To resolve this, enable at least one bit in the Bake Mask property."
msgstr ""
"Bake Mask chưa bật bit nào, nghĩa là quá trình nướng sẽ không tạo ra lưới "
"che chắn cho OccluderInstance3D này.\n"
"Để khắc phục, hãy bật ít nhất một bit trong thuộc tính Bake Mask."

#: scene/3d/occluder_instance_3d.cpp
msgid ""
"No occluder mesh is defined in the Occluder property, so no occlusion "
"culling will be performed using this OccluderInstance3D.\n"
"To resolve this, set the Occluder property to one of the primitive occluder "
"types or bake the scene meshes by selecting the OccluderInstance3D and "
"pressing the Bake Occluders button at the top of the 3D editor viewport."
msgstr ""
"Chưa xác định occluder mesh trong thuộc tính Occluder, do đó occlusion "
"culling sẽ không được thực hiện.\n"
"Để khắc phục, hãy đặt thuộc tính Occluder thành một trong các kiểu che chắn "
"cơ bản hoặc nướng các mesh trong scene bằng cách chọn OccluderInstance3D và "
"nhấn nút Bake Occluders ở phía trên viewport chỉnh sửa 3D."

#: scene/3d/occluder_instance_3d.cpp
msgid ""
"The occluder mesh has less than 3 vertices, so no occlusion culling will be "
"performed using this OccluderInstance3D.\n"
"To generate a proper occluder mesh, select the OccluderInstance3D then use "
"the Bake Occluders button at the top of the 3D editor viewport."
msgstr ""
"Occluder mesh có ít hơn 3 đỉnh, do đó occlusion culling sẽ không được thực "
"hiện.\n"
"Để tạo occluder mesh hợp lệ, hãy chọn OccluderInstance3D rồi sử dụng nút "
"Bake Occluders ở phía trên viewport chỉnh sửa 3D."

#: scene/3d/occluder_instance_3d.cpp
msgid ""
"The polygon occluder has less than 3 vertices, so no occlusion culling will "
"be performed using this OccluderInstance3D.\n"
"Vertices can be added in the inspector or using the polygon editing tools at "
"the top of the 3D editor viewport."
msgstr ""
"Polygon occluder có ít hơn 3 đỉnh, do đó occlusion culling sẽ không được "
"thực hiện.\n"
"Có thể thêm đỉnh trong inspector hoặc sử dụng các công cụ chỉnh sửa đa giác "
"ở phía trên viewport chỉnh sửa 3D."

#: scene/3d/path_3d.cpp
msgid "PathFollow3D only works when set as a child of a Path3D node."
msgstr "PathFollow3D chỉ hoạt động khi được đặt làm con của node Path3D."

#: scene/3d/path_3d.cpp
msgid ""
"PathFollow3D's ROTATION_ORIENTED requires \"Up Vector\" to be enabled in its "
"parent Path3D's Curve resource."
msgstr ""
"Chế độ ROTATION_ORIENTED của PathFollow3D yêu cầu phải bật \"Up Vector\" "
"trong tài nguyên Curve của Path3D cha."

#: scene/3d/physics/collision_object_3d.cpp
msgid ""
"This node has no shape, so it can't collide or interact with other objects.\n"
"Consider adding a CollisionShape3D or CollisionPolygon3D as a child to "
"define its shape."
msgstr ""
"Node này không có hình dạng, vì vậy nó không thể va chạm hoặc tương tác với "
"các đối tượng khác.\n"
"Hãy cân nhắc thêm CollisionShape3D hoặc CollisionPolygon3D làm con để định "
"nghĩa hình dạng."

#: scene/3d/physics/collision_object_3d.cpp
msgid ""
"With a non-uniform scale this node will probably not function as expected.\n"
"Please make its scale uniform (i.e. the same on all axes), and change the "
"size in children collision shapes instead."
msgstr ""
"Với tỉ lệ không đồng đều, node này có thể sẽ không hoạt động như mong đợi.\n"
"Vui lòng chỉnh scale đồng đều (giống nhau trên tất cả các trục) và thay đổi "
"kích thước của các hình dạng va chạm con thay thế."

#: scene/3d/physics/collision_polygon_3d.cpp
msgid ""
"CollisionPolygon3D only serves to provide a collision shape to a "
"CollisionObject3D derived node.\n"
"Please only use it as a child of Area3D, StaticBody3D, RigidBody3D, "
"CharacterBody3D, etc. to give them a shape."
msgstr ""
"CollisionPolygon3D chỉ có mục đích là cung cấp hình dạng va chạm cho những "
"nút kế thừa từ CollisionObject3D.\n"
"Cho nên hãy dùng nó như là nút con của Area3D, StaticBody3D, RigidBody3D, "
"v.v để thêm hình dạng cho chúng."

#: scene/3d/physics/collision_polygon_3d.cpp
msgid "An empty CollisionPolygon3D has no effect on collision."
msgstr "CollisionPolygon3D trống không có tác dụng va chạm."

#: scene/3d/physics/collision_polygon_3d.cpp
msgid ""
"A non-uniformly scaled CollisionPolygon3D node will probably not function as "
"expected.\n"
"Please make its scale uniform (i.e. the same on all axes), and change its "
"polygon's vertices instead."
msgstr ""
"CollisionPolygon3D với tỉ lệ không đồng đều có thể sẽ không hoạt động như "
"mong đợi.\n"
"Vui lòng chỉnh scale đồng đều và thay đổi các đỉnh của đa giác thay thế."

#: scene/3d/physics/collision_shape_3d.cpp
msgid ""
"CollisionShape3D only serves to provide a collision shape to a "
"CollisionObject3D derived node.\n"
"Please only use it as a child of Area3D, StaticBody3D, RigidBody3D, "
"CharacterBody3D, etc. to give them a shape."
msgstr ""
"CollisionShape3D chỉ có mục đích là cung cấp hình dạng va chạm cho những nút "
"kế thừa từ CollisionObject3D.\n"
"Cho nên hãy dùng nó như là nút con của Area3D, StaticBody3D, RigidBody3D, "
"v.v để thêm hình dạng cho chúng."

#: scene/3d/physics/collision_shape_3d.cpp
msgid ""
"A shape must be provided for CollisionShape3D to function. Please create a "
"shape resource for it."
msgstr ""
"Phải cung cấp một hình dạng để CollisionShape3D hoạt động. Vui lòng tạo tài "
"nguyên hình dạng cho nó."

#: scene/3d/physics/collision_shape_3d.cpp
msgid ""
"When used for collision, ConcavePolygonShape3D is intended to work with "
"static CollisionObject3D nodes like StaticBody3D.\n"
"It will likely not behave well for %ss (except when frozen and freeze_mode "
"set to FREEZE_MODE_STATIC)."
msgstr ""
"Khi dùng để va chạm, ConcavePolygonShape3D được thiết kế để làm việc với các "
"node CollisionObject3D tĩnh như StaticBody3D.\n"
"Nó có thể sẽ không hoạt động tốt với %ss (trừ khi đã đóng băng và đặt "
"freeze_mode là FREEZE_MODE_STATIC)."

#: scene/3d/physics/collision_shape_3d.cpp
msgid ""
"WorldBoundaryShape3D doesn't support RigidBody3D in another mode than static."
msgstr ""
"WorldBoundaryShape3D không hỗ trợ RigidBody3D ở các chế độ khác ngoài chế độ "
"tĩnh (static)."

#: scene/3d/physics/collision_shape_3d.cpp
msgid ""
"When used for collision, ConcavePolygonShape3D is intended to work with "
"static CollisionObject3D nodes like StaticBody3D.\n"
"It will likely not behave well for CharacterBody3Ds."
msgstr ""
"Khi dùng để va chạm, ConcavePolygonShape3D được thiết kế để làm việc với các "
"node CollisionObject3D tĩnh như StaticBody3D.\n"
"Nó có thể sẽ không hoạt động tốt với CharacterBody3Ds."

#: scene/3d/physics/collision_shape_3d.cpp
msgid ""
"A non-uniformly scaled CollisionShape3D node will probably not function as "
"expected.\n"
"Please make its scale uniform (i.e. the same on all axes), and change the "
"size of its shape resource instead."
msgstr ""
"CollisionShape3D với tỉ lệ không đồng đều có thể sẽ không hoạt động như mong "
"đợi.\n"
"Vui lòng chỉnh scale đồng đều và thay đổi kích thước của tài nguyên hình "
"dạng thay thế."

#: scene/3d/physics/joints/joint_3d.cpp
msgid "Node A and Node B must be PhysicsBody3Ds"
msgstr "Node A và Node B phải là PhysicsBody3D"

#: scene/3d/physics/joints/joint_3d.cpp
msgid "Node A must be a PhysicsBody3D"
msgstr "Node A phải là PhysicsBody3D"

#: scene/3d/physics/joints/joint_3d.cpp
msgid "Node B must be a PhysicsBody3D"
msgstr "Node B phải là PhysicsBody3D"

#: scene/3d/physics/joints/joint_3d.cpp
msgid "Joint is not connected to any PhysicsBody3Ds"
msgstr "Khớp nối không được kết nối với bất kỳ PhysicsBody3D nào"

#: scene/3d/physics/joints/joint_3d.cpp
msgid "Node A and Node B must be different PhysicsBody3Ds"
msgstr "Node A và Node B phải là các PhysicsBody3D khác nhau"

#: scene/3d/physics/physics_body_3d.cpp
msgid ""
"PhysicsBody3D will not work correctly on a non-interpolated branch of the "
"SceneTree.\n"
"Check the node's inherited physics_interpolation_mode."
msgstr ""
"PhysicsBody3D sẽ không hoạt động đúng trên nhánh không nội suy của "
"SceneTree.\n"
"Kiểm tra lại thuộc tính physics_interpolation_mode của node."

#: scene/3d/physics/rigid_body_3d.cpp
msgid ""
"Scale changes to RigidBody3D will be overridden by the physics engine when "
"running.\n"
"Please change the size in children collision shapes instead."
msgstr ""
"Thay đổi tỷ lệ đối với RigidBody3D sẽ bị ghi đè bởi công cụ vật lý khi đang "
"chạy.\n"
"Vui lòng thay đổi kích thước trong các hình dạng va chạm con."

#: scene/3d/physics/shape_cast_3d.cpp
msgid ""
"This node cannot interact with other objects unless a Shape3D is assigned."
msgstr ""
"Node này không thể tương tác với các đối tượng khác trừ khi được gán Shape3D."

#: scene/3d/physics/shape_cast_3d.cpp
msgid ""
"ShapeCast3D does not support ConcavePolygonShape3Ds. Collisions will not be "
"reported."
msgstr ""
"ShapeCast3D không hỗ trợ ConcavePolygonShape3Ds. Các va chạm sẽ không được "
"báo cáo."

#: scene/3d/physics/soft_body_3d.cpp
msgid "This body will be ignored until you set a mesh."
msgstr "Body này sẽ bị bỏ qua cho đến khi bạn đặt một mesh cho nó."

#: scene/3d/physics/vehicle_body_3d.cpp
msgid ""
"VehicleWheel3D serves to provide a wheel system to a VehicleBody3D. Please "
"use it as a child of a VehicleBody3D."
msgstr ""
"VehicleWheel3D dùng để cung cấp hệ thống bánh xe cho VehicleBody3D. Vui lòng "
"đặt nó làm con của VehicleBody3D."

#: scene/3d/remote_transform_3d.cpp
msgid ""
"The \"Remote Path\" property must point to a valid Node3D or Node3D-derived "
"node to work."
msgstr ""
"Thuộc tính \"Remote Path\" phải trỏ tới một node Node3D hợp lệ hoặc node kế "
"thừa từ Node3D để hoạt động."

#: scene/3d/retarget_modifier_3d.cpp
msgid "There is no child Skeleton3D!"
msgstr "Không có node con Skeleton3D!"

#: scene/3d/skeleton_modifier_3d.cpp
msgid ""
"Skeleton3D node not set! SkeletonModifier3D must be child of Skeleton3D."
msgstr ""
"Chưa thiết lập node Skeleton3D! SkeletonModifier3D bắt buộc phải là con của "
"Skeleton3D."

#: scene/3d/spline_ik_3d.cpp
msgid ""
"Detecting settings with no Path3D set! SplineIK3D must have a Path3D to work."
msgstr ""
"Chưa thiết lập Path3D! SplineIK3D cần phải có Path3D mới hoạt động được."

#: scene/3d/spring_bone_collision_3d.cpp
msgid "Parent node should be a SpringBoneSimulator3D node."
msgstr "Node cha nên là một node SpringBoneSimulator3D."

#: scene/3d/sprite_3d.cpp
msgid ""
"A SpriteFrames resource must be created or set in the \"Sprite Frames\" "
"property in order for AnimatedSprite3D to display frames."
msgstr ""
"Tài nguyên SpriteFrames phải được tạo hoặc thiết lập trong thuộc tính "
"\"Sprite Frames\" để AnimatedSprite3D hiển thị các khung hình."

#: scene/3d/two_bone_ik_3d.cpp
msgid ""
"Detecting settings with no target set! TwoBoneIK3D must have a target to "
"work."
msgstr ""
"Chưa thiết lập đích (target)! TwoBoneIK3D cần phải có đích mới hoạt động "
"được."

#: scene/3d/two_bone_ik_3d.cpp
msgid ""
"Detecting settings with no pole target set! TwoBoneIK3D must have a pole "
"target to work."
msgstr ""
"Chưa thiết lập cực đích (pole target)! TwoBoneIK3D cần phải có pole target "
"mới hoạt động được."

#: scene/3d/visual_instance_3d.cpp
msgid ""
"The GeometryInstance3D visibility range's End distance is set to a non-zero "
"value, but is lower than the Begin distance.\n"
"This means the GeometryInstance3D will never be visible.\n"
"To resolve this, set the End distance to 0 or to a value greater than the "
"Begin distance."
msgstr ""
"Khoảng cách Kết thúc (End distance) của tầm nhìn GeometryInstance3D được đặt "
"khác 0, nhưng lại thấp hơn Khoảng cách Bắt đầu (Begin distance).\n"
"Điều này có nghĩa là GeometryInstance3D sẽ không bao giờ hiển thị.\n"
"Để khắc phục, hãy đặt End distance bằng 0 hoặc lớn hơn Begin distance."

#: scene/3d/visual_instance_3d.cpp
msgid ""
"The GeometryInstance3D is configured to fade in smoothly over distance, but "
"the fade transition distance is set to 0.\n"
"To resolve this, increase Visibility Range Begin Margin above 0."
msgstr ""
"GeometryInstance3D được cấu hình để mờ dần theo khoảng cách, nhưng khoảng "
"cách chuyển tiếp làm mờ đang bằng 0.\n"
"Để khắc phục, hãy tăng Visibility Range Begin Margin lên trên 0."

#: scene/3d/visual_instance_3d.cpp
msgid ""
"The GeometryInstance3D is configured to fade out smoothly over distance, but "
"the fade transition distance is set to 0.\n"
"To resolve this, increase Visibility Range End Margin above 0."
msgstr ""
"GeometryInstance3D được cấu hình để mờ dần theo khoảng cách, nhưng khoảng "
"cách chuyển tiếp làm mờ đang bằng 0.\n"
"Để khắc phục, hãy tăng Visibility Range End Margin lên trên 0."

#: scene/3d/visual_instance_3d.cpp
msgid ""
"GeometryInstance3D transparency is only available when using the Forward+ "
"renderer."
msgstr ""
"Độ trong suốt của GeometryInstance3D chỉ khả dụng khi sử dụng trình kết xuất "
"Forward+."

#: scene/3d/visual_instance_3d.cpp
msgid ""
"GeometryInstance3D visibility range transparency fade is only available when "
"using the Forward+ renderer."
msgstr ""
"Độ mờ dần theo phạm vi hiển thị của GeometryInstance3D chỉ khả dụng khi sử "
"dụng trình kết xuất Forward+."

#: scene/3d/voxel_gi.cpp
msgid "Plotting Meshes"
msgstr "Đang vẽ Meshes"

#: scene/3d/voxel_gi.cpp
msgid "Generating Distance Field"
msgstr "Đang tạo Trường Khoảng cách (Distance Field)"

#: scene/3d/voxel_gi.cpp
msgid "Finishing Plot"
msgstr "Đang hoàn tất việc vẽ"

#: scene/3d/voxel_gi.cpp
msgid ""
"VoxelGI nodes are not supported when using the Compatibility renderer yet. "
"Support will be added in a future release."
msgstr ""
"Node VoxelGI chưa được hỗ trợ khi dùng trình kết xuất Compatibility. Hỗ trợ "
"sẽ được thêm trong bản cập nhật tương lai."

#: scene/3d/voxel_gi.cpp
msgid "VoxelGI nodes are not supported when using the Dummy renderer."
msgstr "Node VoxelGI không được hỗ trợ khi sử dụng trình kết xuất Dummy."

#: scene/3d/voxel_gi.cpp
msgid ""
"No VoxelGI data set, so this node is disabled. Bake static objects to enable "
"GI."
msgstr ""
"Chưa thiết lập dữ liệu VoxelGI nên node này bị vô hiệu hóa. Hãy nướng các "
"vật thể tĩnh để bật GI."

#: scene/3d/world_environment.cpp
msgid ""
"To have any visible effect, WorldEnvironment requires its \"Environment\" "
"property to contain an Environment, its \"Camera Attributes\" property to "
"contain a CameraAttributes resource, or both."
msgstr ""
"Để có hiệu ứng hiển thị, WorldEnvironment yêu cầu thuộc tính \"Environment\" "
"phải chứa một Environment, hoặc thuộc tính \"Camera Attributes\" phải chứa "
"tài nguyên CameraAttributes, hoặc cả hai."

#: scene/3d/world_environment.cpp
msgid ""
"Only one WorldEnvironment is allowed per scene (or set of instantiated "
"scenes)."
msgstr ""
"Mỗi scene (hoặc tập hợp các scene được khởi tạo) chỉ được phép có một "
"WorldEnvironment."

#: scene/3d/xr/xr_nodes.cpp
msgid ""
"XRCamera3D may not function as expected without an XROrigin3D node as its "
"parent."
msgstr ""
"XRCamera3D có thể không hoạt động như mong đợi nếu không có node XROrigin3D "
"làm cha."

#: scene/3d/xr/xr_nodes.cpp
msgid ""
"XRCamera3D should have physics_interpolation_mode set to OFF in order to "
"avoid jitter."
msgstr ""
"XRCamera3D nên đặt physics_interpolation_mode là OFF để tránh rung lắc."

#: scene/3d/xr/xr_nodes.cpp
msgid ""
"XRNode3D may not function as expected without an XROrigin3D node as its "
"parent."
msgstr ""
"XRNode3D có thể không hoạt động như mong đợi nếu không có node XROrigin3D "
"làm cha."

#: scene/3d/xr/xr_nodes.cpp
msgid "No tracker name is set."
msgstr "Chưa thiết lập tên tracker."

#: scene/3d/xr/xr_nodes.cpp
msgid "No pose is set."
msgstr "Không có tư thế nào được thiết lập."

#: scene/3d/xr/xr_nodes.cpp
msgid ""
"XRNode3D should have physics_interpolation_mode set to OFF in order to avoid "
"jitter."
msgstr "XRNode3D nên đặt physics_interpolation_mode là OFF để tránh rung lắc."

#: scene/3d/xr/xr_nodes.cpp
msgid "XROrigin3D requires an XRCamera3D child node."
msgstr "XROrigin3D yêu cầu một node con XRCamera3D."

#: scene/3d/xr/xr_nodes.cpp
msgid ""
"Changing the scale on the XROrigin3D node is not supported. Change the World "
"Scale instead."
msgstr ""
"Không hỗ trợ thay đổi tỉ lệ trên node XROrigin3D. Hãy thay đổi World Scale "
"thay thế."

#: scene/3d/xr/xr_nodes.cpp
msgid ""
"XR shaders are not enabled in project settings. Stereoscopic output is not "
"supported unless they are enabled. Please enable `xr/shaders/enabled` to use "
"stereoscopic output."
msgstr ""
"XR shaders chưa được bật trong cài đặt dự án. Đầu ra lập thể (stereoscopic) "
"không được hỗ trợ trừ khi chúng được bật. Vui lòng bật `xr/shaders/enabled` "
"để sử dụng đầu ra lập thể."

#: scene/animation/animation_blend_tree.cpp
msgid "Animation '%s' not found."
msgstr "Không tìm thấy hoạt ảnh '%s'."

#: scene/animation/animation_blend_tree.cpp
msgid "Nothing connected to output."
msgstr "Không có gì được kết nối với đầu ra."

#: scene/animation/animation_mixer.cpp
msgid "Animation Apply Reset"
msgstr "Áp dụng Thiết lập lại Hoạt ảnh"

#: scene/animation/animation_node_state_machine.cpp
msgid "No playback resource set at path: %s."
msgstr "Không có tài nguyên phát lại nào được thiết lập tại đường dẫn: %s."

#: scene/animation/animation_tree.cpp
msgid "Nothing connected to input %d."
msgstr "Không có gì được kết nối với đầu ra %d."

#: scene/animation/animation_tree.cpp
msgid "No root AnimationNode for the graph is set."
msgstr "Chưa thiết lập AnimationNode gốc cho đồ thị."

#: scene/animation/animation_tree.cpp
msgid ""
"The AnimationTree is inactive.\n"
"Activate it in the inspector to enable playback; check node warnings if "
"activation fails."
msgstr ""
"AnimationTree đang không hoạt động.\n"
"Hãy kích hoạt nó trong trình kiểm tra (inspector) để phát lại; kiểm tra cảnh "
"báo của node nếu việc kích hoạt thất bại."

#: scene/animation/animation_tree.cpp
msgid ""
"The AnimationTree node (or one of its ancestors) has its process mode set to "
"Disabled.\n"
"Change the process mode in the inspector to allow playback."
msgstr ""
"Node AnimationTree (hoặc một trong các node cha) đang có process mode là "
"Disabled.\n"
"Hãy thay đổi process mode trong inspector để cho phép phát hoạt ảnh."

#: scene/debugger/view_3d_controller.cpp
msgid "Top Orthogonal"
msgstr "Trực giao từ trên xuống"

#: scene/debugger/view_3d_controller.cpp
msgid "Top Perspective"
msgstr "Phối cảnh từ trên xuống"

#: scene/debugger/view_3d_controller.cpp
msgid "Bottom Orthogonal"
msgstr "Trực giao từ dưới lên"

#: scene/debugger/view_3d_controller.cpp
msgid "Bottom Perspective"
msgstr "Phối cảnh từ dưới lên"

#: scene/debugger/view_3d_controller.cpp
msgid "Left Orthogonal"
msgstr "Trực giao từ trái"

#: scene/debugger/view_3d_controller.cpp
msgid "Left Perspective"
msgstr "Phối cảnh từ trái"

#: scene/debugger/view_3d_controller.cpp
msgid "Right Orthogonal"
msgstr "Trực giao từ phải"

#: scene/debugger/view_3d_controller.cpp
msgid "Right Perspective"
msgstr "Phối cảnh từ phải"

#: scene/debugger/view_3d_controller.cpp
msgid "Front Orthogonal"
msgstr "Trực giao từ trước"

#: scene/debugger/view_3d_controller.cpp
msgid "Front Perspective"
msgstr "Phối cảnh từ trước"

#: scene/debugger/view_3d_controller.cpp
msgid "Rear Orthogonal"
msgstr "Trực giao từ sau"

#: scene/debugger/view_3d_controller.cpp
msgid "Rear Perspective"
msgstr "Phối cảnh từ sau"

#. TRANSLATORS: This will be appended to the view name when Auto Orthogonal is enabled.
#: scene/debugger/view_3d_controller.cpp
msgid "[auto]"
msgstr "[tự động]"

#: scene/gui/base_button.cpp
msgid ""
"ButtonGroup is intended to be used only with buttons that have toggle_mode "
"set to true."
msgstr ""
"ButtonGroup chỉ nên được sử dụng với các nút có thuộc tính toggle_mode là "
"true."

#: scene/gui/color_picker.cpp
msgid "The changes to this palette have not been saved to a file."
msgstr "Các thay đổi đối với bảng màu này chưa được lưu vào tệp."

#: scene/gui/color_picker.cpp
msgid "Execute an expression as a color."
msgstr "Thực thi một biểu thức dưới dạng màu sắc."

#: scene/gui/color_picker.cpp
msgid "Load existing color palette."
msgstr "Tải bảng màu hiện có."

#: scene/gui/color_picker.cpp
msgid "Switch between hexadecimal and code values."
msgstr "Chuyển đổi giữa giá trị thập lục phân và mã."

#: scene/gui/container.cpp
msgid ""
"Container by itself serves no purpose unless a script configures its "
"children placement behavior.\n"
"If you don't intend to add a script, use a plain Control node instead."
msgstr ""
"Bản thân Container không có mục đích sử dụng trừ khi có script cấu hình hành "
"vi sắp xếp các node con.\n"
"Nếu bạn không định thêm script, hãy sử dụng node Control thông thường."

#: scene/gui/control.cpp
msgid ""
"The Hint Tooltip won't be displayed as the control's Mouse Filter is set to "
"\"Ignore\". To solve this, set the Mouse Filter to \"Stop\" or \"Pass\"."
msgstr ""
"Hint Tooltip sẽ không hiển thị vì Mouse Filter của control đang là "
"\"Ignore\". Để khắc phục, hãy đặt Mouse Filter thành \"Stop\" hoặc \"Pass\"."

#: scene/gui/control.cpp scene/main/window.cpp
msgid "Accessibility Name must not be empty, or contain only spaces."
msgstr ""
"Tên truy cập (Accessibility Name) không được để trống hoặc chỉ chứa dấu cách."

#: scene/gui/control.cpp scene/main/window.cpp
msgid "Accessibility Name must not include Node class name."
msgstr "Tên truy cập không được chứa tên lớp Node."

#: scene/gui/control.cpp scene/main/window.cpp
msgid "Accessibility Name must not include control character."
msgstr "Tên truy cập không được chứa các ký tự điều khiển."

#: scene/gui/control.cpp
msgid "%s grabbed. Select target and use %s to drop, use %s to cancel."
msgstr "%s đã được chọn. Chọn đích đến và nhấn %s để thả, nhấn %s để hủy."

#: scene/gui/control.cpp
msgid "%s can be dropped here. Use %s to drop, use %s to cancel."
msgstr "%s có thể thả vào đây. Nhấn %s để thả, nhấn %s để hủy."

#: scene/gui/control.cpp
msgid "%s can not be dropped here. Use %s to cancel."
msgstr "%s không thể thả vào đây. Nhấn %s để hủy."

#: scene/gui/label.cpp
msgid ""
"Labels with autowrapping enabled must have a positive custom maximum width "
"configured to work correctly."
msgstr ""
"Các nhãn (Labels) đã bật autowrapping phải có chiều rộng tối đa tùy chỉnh "
"lớn hơn 0 mới hoạt động đúng."

#: scene/gui/label.cpp
msgid ""
"The current font does not support rendering one or more characters used in "
"this Label's text."
msgstr ""
"Phông chữ hiện tại không hỗ trợ hiển thị một hoặc nhiều ký tự được sử dụng "
"trong văn bản của Label này."

#: scene/gui/label.cpp
msgid ""
"MSDF font pixel range is too small, some outlines/shadows will not render. "
"Set MSDF pixel range to be at least %d to render all outlines/shadows."
msgstr ""
"Phạm vi pixel phông chữ MSDF quá nhỏ, một số đường viền/đổ bóng sẽ không "
"được hiển thị. Hãy đặt phạm vi pixel MSDF ít nhất là %d để hiển thị tất cả "
"đường viền/đổ bóng."

#: scene/gui/popup.cpp scene/gui/popup_menu.cpp
msgid ""
"The current theme style has shadows and/or rounded corners for popups, but "
"those won't display correctly if \"display/window/per_pixel_transparency/"
"allowed\" isn't enabled in the Project Settings, nor if it isn't supported."
msgstr ""
"Kiểu giao diện hiện tại có đổ bóng và/hoặc bo góc cho cửa sổ popup, nhưng "
"chúng sẽ không hiển thị đúng nếu tùy chọn \"display/window/"
"per_pixel_transparency/allowed\" chưa được bật trong Cài đặt Dự án, hoặc "
"thiết bị không hỗ trợ."

#: scene/gui/range.cpp
msgid ""
"If \"Exp Edit\" is enabled, \"Min Value\" must be greater or equal to 0."
msgstr ""
"Nếu bật \"Exp Edit\", \"Giá trị Tối thiểu\" (Min Value) phải lớn hơn hoặc "
"bằng 0."

#: scene/gui/rich_text_label.cpp
msgid "Image alternative text must not be empty."
msgstr "Văn bản thay thế cho hình ảnh không được để trống."

#: scene/gui/scroll_container.cpp
msgid ""
"ScrollContainer is intended to work with a single child control.\n"
"Use a container as child (VBox, HBox, etc.), or a Control and set the custom "
"minimum size manually."
msgstr ""
"ScrollContainer được thiết kế để làm việc với một control con duy nhất.\n"
"Hãy sử dụng một container làm con (VBox, HBox, v.v.), hoặc một Control và "
"thiết lập kích thước tối thiểu tùy chỉnh thủ công."

#: scene/gui/split_container.cpp
msgid "Drag to resize"
msgstr "Kéo để thay đổi kích thước"

#: scene/gui/subviewport_container.cpp
msgid ""
"This node doesn't have a SubViewport as child, so it can't display its "
"intended content.\n"
"Consider adding a SubViewport as a child to provide something displayable."
msgstr ""
"Node này không có SubViewport làm con, nên không thể hiển thị nội dung mong "
"muốn.\n"
"Hãy xem xét thêm SubViewport làm con để cung cấp nội dung hiển thị được."

#: scene/gui/subviewport_container.cpp
msgid ""
"The default mouse cursor shape of SubViewportContainer has no effect.\n"
"Consider leaving it at its initial value `CURSOR_ARROW`."
msgstr ""
"Hình dạng con trỏ chuột mặc định của SubViewportContainer không có tác "
"dụng.\n"
"Hãy cân nhắc giữ nguyên giá trị ban đầu `CURSOR_ARROW`."

#: scene/gui/texture_rect.cpp
msgid ""
"STRETCH_TILE mode is not supported for an AtlasTexture with non-zero margin."
msgstr ""
"Chế độ STRETCH_TILE không được hỗ trợ cho AtlasTexture có lề khác không."

#: scene/gui/tree.cpp
msgid "Cell %d x %d: either text or alternative text must not be empty."
msgstr "Ô %d x %d: văn bản hoặc văn bản thay thế không được để trống."

#: scene/gui/tree.cpp
msgid "Button %d in %d x %d: alternative text must not be empty."
msgstr "Nút %d tại %d x %d: văn bản thay thế không được để trống."

#: scene/main/canvas_item.cpp
msgid ""
"Ancestor \"%s\" clips its children, so this node will not be able to clip "
"its children."
msgstr ""
"Node cha \"%s\" đã cắt nội dung con, nên node này sẽ không thể cắt nội dung "
"con của chính nó."

#: scene/main/canvas_item.cpp
msgid ""
"Ancestor \"%s\" is a CanvasGroup, so this node will not be able to clip its "
"children."
msgstr ""
"Node cha \"%s\" là một CanvasGroup, nên node này sẽ không thể cắt nội dung "
"con."

#: scene/main/missing_node.cpp
msgid ""
"This node was an instance of scene '%s', which was no longer available when "
"this scene was loaded."
msgstr ""
"Node này là một thể hiện của cảnh '%s', cảnh này hiện không còn khả dụng khi "
"tải."

#: scene/main/missing_node.cpp
msgid ""
"Saving current scene will discard instance and all its properties, including "
"editable children edits (if existing)."
msgstr ""
"Lưu cảnh hiện tại sẽ loại bỏ thể hiện và tất cả thuộc tính, bao gồm cả các "
"chỉnh sửa trên node con (nếu có)."

#: scene/main/missing_node.cpp
msgid ""
"This node was saved as class type '%s', which was no longer available when "
"this scene was loaded."
msgstr ""
"Node này được lưu với kiểu lớp '%s', hiện không còn khả dụng khi tải cảnh."

#: scene/main/missing_node.cpp
msgid ""
"Data from the original node is kept as a placeholder until this type of node "
"is available again. It can hence be safely re-saved without risk of data "
"loss."
msgstr ""
"Dữ liệu từ node gốc được giữ làm placeholder cho đến khi kiểu node này khả "
"dụng lại. Do đó, có thể lưu lại an toàn mà không mất dữ liệu."

#: scene/main/missing_node.cpp
msgid "Unrecognized missing node. Check scene dependency errors for details."
msgstr ""
"Nút bị thiếu không được nhận dạng. Kiểm tra lỗi phụ thuộc cảnh để biết chi "
"tiết."

#: scene/main/node.h
msgid ""
"This node is marked as deprecated and will be removed in future versions.\n"
"Please check the Godot documentation for information about migration."
msgstr ""
"Node này được đánh dấu là không dùng nữa (deprecated) và sẽ bị xóa trong các "
"phiên bản tương lai.\n"
"Vui lòng kiểm tra tài liệu Godot để biết thông tin di chuyển."

#: scene/main/node.h
msgid ""
"This node is marked as experimental and may be subject to removal or major "
"changes in future versions."
msgstr ""
"Node này được đánh dấu là thử nghiệm (experimental) và có thể bị xóa hoặc "
"thay đổi lớn trong tương lai."

#: scene/main/shader_globals_override.cpp
msgid ""
"ShaderGlobalsOverride is not active because another node of the same type is "
"in the scene."
msgstr ""
"ShaderGlobalsOverride không hoạt động vì đã có một node cùng kiểu trong cảnh."

#: scene/main/timer.cpp
msgid ""
"Very low timer wait times (< 0.05 seconds) may behave in significantly "
"different ways depending on the rendered or physics frame rate.\n"
"Consider using a script's process loop instead of relying on a Timer for "
"very low wait times."
msgstr ""
"Thời gian chờ của Timer rất thấp (< 0.05 giây) có thể hoạt động khác biệt "
"tùy thuộc vào tốc độ khung hình (frame rate) hoặc vật lý.\n"
"Hãy cân nhắc sử dụng vòng lặp process trong script thay vì dựa vào Timer cho "
"các khoảng thời gian rất thấp."

#: scene/main/viewport.cpp
msgid "Drag-and-drop data"
msgstr "Dữ liệu kéo-và-thả"

#: scene/main/viewport.cpp
msgid ""
"The Viewport size must be greater than or equal to 2 pixels on both "
"dimensions to render anything."
msgstr ""
"Kích thước Viewport phải lớn hơn hoặc bằng 2 pixel ở cả hai chiều để kết "
"xuất nội dung."

#: scene/resources/packed_scene.cpp
msgid ""
"An incoming node's name clashes with %s already in the scene (presumably, "
"from a more nested instance).\n"
"The less nested node will be renamed. Please fix and re-save the scene."
msgstr ""
"Tên của node đang thêm vào bị trùng với %s trong cảnh (có lẽ từ một thể hiện "
"lồng sâu hơn).\n"
"Node ít lồng hơn sẽ được đổi tên. Vui lòng sửa và lưu lại cảnh."

#: servers/rendering/shader_language.cpp
msgid "Division by zero error."
msgstr "Lỗi chia cho số không."

#: servers/rendering/shader_language.cpp
msgid "Modulo by zero error."
msgstr "Lỗi chia lấy dư cho số không."

#: servers/rendering/shader_language.cpp
msgid ""
"Invalid number of arguments when calling stage function '%s', which expects "
"%d argument(s)."
msgstr ""
"Số lượng đối số không hợp lệ khi gọi hàm stage '%s', hàm này mong đợi %d đối "
"số."

#: servers/rendering/shader_language.cpp
msgid ""
"Invalid argument type when calling stage function '%s', type expected is "
"'%s'."
msgstr ""
"Kiểu đối số không hợp lệ khi gọi hàm stage '%s', kiểu mong đợi là '%s'."

#: servers/rendering/shader_language.cpp
msgid "Expected integer constant within [%d..%d] range."
msgstr "Mong đợi hằng số nguyên trong phạm vi [%d..%d]."

#: servers/rendering/shader_language.cpp
msgid "Argument %d of function '%s' is not a variable, array, or member."
msgstr "Đối số %d của hàm '%s' không phải là biến, mảng hoặc thành viên."

#: servers/rendering/shader_language.cpp
msgid "Varyings cannot be passed for the '%s' parameter."
msgstr "Varying không thể là tham số '%s'."

#: servers/rendering/shader_language.cpp
msgid "A constant value cannot be passed for the '%s' parameter."
msgstr "Không thể truyền giá trị hằng cho tham số '%s'."

#: servers/rendering/shader_language.cpp
msgid ""
"Argument %d of function '%s' can only take a local variable, array, or "
"member."
msgstr ""
"Đối số %d của hàm '%s' chỉ có thể là biến cục bộ, mảng hoặc thành viên."

#: servers/rendering/shader_language.cpp
msgid "Built-in function \"%s(%s)\" is only supported on high-end platforms."
msgstr "Hàm tích hợp \"%s(%s)\" chỉ được hỗ trợ trên các nền tảng cao cấp."

#: servers/rendering/shader_language.cpp
msgid "Invalid arguments for the built-in function: \"%s(%s)\"."
msgstr "Tham số không hợp lệ cho hàm tích hợp sắn: \"%s(%s)\"."

#: servers/rendering/shader_language.cpp
msgid "Recursion is not allowed."
msgstr "Đệ quy không được cho phép."

#: servers/rendering/shader_language.cpp
msgid "Function '%s' can't be called from source code."
msgstr "Hàm '%s' không thể được gọi từ mã nguồn."

#: servers/rendering/shader_language.cpp
msgid "No matching function for \"%s\" call:"
msgstr "Không tìm thấy hàm phù hợp cho lời gọi \"%s\":"

#: servers/rendering/shader_language.cpp
msgid ""
"candidate function \"%s(%s)\" not viable, argument %d should be %s but is %s."
msgstr ""
"hàm ứng viên \"%s(%s)\" không khả thi, đối số %d mong đợi là %s nhưng lại là "
"%s."

#: servers/rendering/shader_language.cpp
msgid ""
"Too few arguments for \"%s(%s)\" call. Expected at least %d but received %d."
msgstr ""
"Thiếu đối số cho lời gọi \"%s(%s)\". Mong đợi ít nhất %d nhưng nhận được %d."

#: servers/rendering/shader_language.cpp
msgid ""
"Too many arguments for \"%s(%s)\" call. Expected at most %d but received %d."
msgstr ""
"Quá nhiều đối số cho lời gọi \"%s(%s)\". Mong đợi tối đa %d nhưng nhận được "
"%d."

#: servers/rendering/shader_language.cpp
msgid "Invalid assignment of '%s' to '%s'."
msgstr "Phép gán không hợp lệ '%s' cho '%s'."

#: servers/rendering/shader_language.cpp
msgid "Expected constant expression."
msgstr "Mong đợi một biểu thức hằng."

#: servers/rendering/shader_language.cpp
msgid "Expected ',' or ')' after argument."
msgstr "Mong đợi ',' hoặc ')' sau đối số."

#: servers/rendering/shader_language.cpp
msgid "Varying may not be assigned in the '%s' function."
msgstr "Varying không được phép gán trong hàm '%s'."

#: servers/rendering/shader_language.cpp
msgid "Varying with '%s' data type may only be assigned in the '%s' function."
msgstr "Varying với kiểu dữ liệu '%s' chỉ được phép gán trong hàm '%s'."

#: servers/rendering/shader_language.cpp
msgid ""
"Varyings which assigned in '%s' function may not be reassigned in '%s' or "
"'%s'."
msgstr ""
"Các Varying đã được gán trong hàm '%s' không được phép gán lại trong '%s' "
"hoặc '%s'."

#: servers/rendering/shader_language.cpp
msgid "'%s' cannot be used within the '%s' processor function."
msgstr "'%s' không thể được sử dụng ngoài hàm xử lý '%s'."

#: servers/rendering/shader_language.cpp
msgid ""
"'%s' cannot be used here, because '%s' is called by the '%s' processor "
"function (which is not allowed)."
msgstr ""
"'%s' không thể sử dụng tại đây, vì '%s' được gọi bởi hàm xử lý '%s' (điều "
"này không được phép)."

#: servers/rendering/shader_language.cpp
msgid "Assignment to function."
msgstr "Phép gán cho hàm."

#: servers/rendering/shader_language.cpp
msgid "Swizzling assignment contains duplicates."
msgstr ""
"Phép gán swizzling (đảo thành phần vector) chứa các thành phần trùng lặp."

#: servers/rendering/shader_language.cpp
msgid "Assignment to uniform."
msgstr "Phép gán cho uniform."

#: servers/rendering/shader_language.cpp
msgid "Constants cannot be modified."
msgstr "Không thể chỉnh sửa hằng số."

#: servers/rendering/shader_language.cpp
msgid ""
"Sampler argument %d of function '%s' called more than once using both built-"
"ins and uniform textures, this is not supported (use either one or the "
"other)."
msgstr ""
"Đối số Sampler %d của hàm '%s' được gọi nhiều lần bằng cả texture tích hợp "
"và uniform, điều này không được hỗ trợ (chỉ được dùng một trong hai)."

#: servers/rendering/shader_language.cpp
msgid ""
"Sampler argument %d of function '%s' called more than once using textures "
"that differ in either filter, repeat, or texture hint setting."
msgstr ""
"Đối số Sampler %d của hàm '%s' được gọi nhiều lần với các texture có cài đặt "
"filter, repeat hoặc hint khác nhau."

#: servers/rendering/shader_language.cpp
msgid ""
"Sampler argument %d of function '%s' called more than once using different "
"built-ins. Only calling with the same built-in is supported."
msgstr ""
"Đối số Sampler %d của hàm '%s' được gọi nhiều lần bằng các texture tích hợp "
"khác nhau. Chỉ hỗ trợ gọi cùng một loại texture tích hợp."

#: servers/rendering/shader_language.cpp
msgid "Array size is already defined."
msgstr "Kích thước mảng đã được định nghĩa."

#: servers/rendering/shader_language.cpp
msgid "Unknown array size is forbidden in that context."
msgstr "Kích thước mảng không xác định bị cấm trong ngữ cảnh này."

#: servers/rendering/shader_language.cpp
msgid "Expected a positive integer constant."
msgstr "Mong đợi một hằng số nguyên dương."

#: servers/rendering/shader_language.cpp
msgid "Invalid data type for the array."
msgstr "Kiểu dữ liệu không hợp lệ cho mảng."

#: servers/rendering/shader_language.cpp
msgid "Array size mismatch. Expected %d elements (found %d)."
msgstr "Kích thước mảng không khớp. Mong đợi %d phần tử (nhưng tìm thấy %d)."

#: servers/rendering/shader_language.cpp
msgid "Expected array initialization."
msgstr "Mong đợi khởi tạo mảng."

#: servers/rendering/shader_language.cpp
msgid "Cannot convert from '%s' to '%s'."
msgstr "Không thể chuyển đổi từ '%s' sang '%s'."

#: servers/rendering/shader_language.cpp
msgid "Expected ')' in expression."
msgstr "Mong đợi ')' trong biểu thức."

#: servers/rendering/shader_language.cpp
msgid "Void value not allowed in expression."
msgstr "Dữ liệu kiểu void không được cho phép trong biểu thức."

#: servers/rendering/shader_language.cpp
msgid "Expected '(' after the type name."
msgstr "Mong đợi '(' sau tên kiểu dữ liệu."

#: servers/rendering/shader_language.cpp
msgid "No matching constructor found for: '%s'."
msgstr "Không tìm thấy hàm khởi tạo (constructor) phù hợp cho: '%s'."

#: servers/rendering/shader_language.cpp
msgid "Expected a function name."
msgstr "Mong đợi một tên hàm."

#: servers/rendering/shader_language.cpp
msgid "Built-in function '%s' is not supported for the '%s' shader type."
msgstr "Hàm tích hợp '%s' không được hỗ trợ cho kiểu shader '%s'."

#: servers/rendering/shader_language.cpp
msgid "No matching function found for: '%s'."
msgstr "Không tìm thấy hàm phù hợp cho: '%s'."

#: servers/rendering/shader_language.cpp
msgid "Varying '%s' cannot be passed for the '%s' parameter in that context."
msgstr ""
"Varying '%s' không thể được truyền cho tham số '%s' trong ngữ cảnh này."

#: servers/rendering/shader_language.cpp
msgid ""
"Unable to pass a multiview texture sampler as a parameter to a custom "
"function. Consider sampling it in the main function and then passing the "
"vector result to the custom function."
msgstr ""
"Không thể truyền sampler texture multiview làm tham số cho hàm tùy chỉnh. "
"Hãy thử sample nó trong hàm chính rồi truyền kết quả vector vào hàm tùy "
"chỉnh."

#: servers/rendering/shader_language.cpp
msgid ""
"Unable to pass RADIANCE texture sampler as a parameter to a custom function. "
"Consider sampling it in the main function and then passing the vector result "
"to the custom function."
msgstr ""
"Không thể truyền sampler texture RADIANCE làm tham số cho hàm tùy chỉnh. Hãy "
"thử sample nó trong hàm chính rồi truyền kết quả vector vào hàm tùy chỉnh."

#: servers/rendering/shader_language.cpp
msgid "Unknown identifier in expression: '%s'."
msgstr "Định danh không xác định trong biểu thức: '%s'."

#: servers/rendering/shader_language.cpp
msgid ""
"%s has been removed in favor of using hint_%s with a uniform.\n"
"To continue with minimal code changes add 'uniform sampler2D %s : hint_%s, "
"filter_linear_mipmap;' near the top of your shader."
msgstr ""
"%s đã bị loại bỏ để thay thế bằng hint_%s với uniform.\n"
"Để tiếp tục với ít thay đổi mã nhất, hãy thêm 'uniform sampler2D %s : "
"hint_%s, filter_linear_mipmap;' ở gần đầu shader của bạn."

#: servers/rendering/shader_language.cpp
msgid "Can't use function as identifier: '%s'."
msgstr "Không thể sử dụng hàm như một định danh: '%s'."

#: servers/rendering/shader_language.cpp
msgid "Varying with '%s' data type may only be used in the '%s' function."
msgstr "Varying với kiểu dữ liệu '%s' chỉ được sử dụng trong hàm '%s'."

#: servers/rendering/shader_language.cpp
msgid "Varying '%s' must be assigned in the '%s' function first."
msgstr "Varying '%s' phải được gán trong hàm '%s' trước."

#: servers/rendering/shader_language.cpp
msgid "Only integer expressions are allowed for indexing."
msgstr ""
"Chỉ các biểu thức số nguyên mới được phép dùng để truy xuất chỉ số "
"(indexing)."

#: servers/rendering/shader_language.cpp
msgid "Index [%d] out of range [%d..%d]."
msgstr "Chỉ số [%d] nằm ngoài phạm vi [%d..%d]."

#: servers/rendering/shader_language.cpp
msgid "Expected expression, found: '%s'."
msgstr "Mong đợi biểu thức, nhưng tìm thấy: '%s'."

#: servers/rendering/shader_language.cpp
msgid "Empty statement. Remove ';' to fix this warning."
msgstr "Câu lệnh rỗng. Hãy xóa ';' để khắc phục cảnh báo này."

#: servers/rendering/shader_language.cpp
msgid "Expected an identifier as a member."
msgstr "Mong đợi một định danh làm thành viên."

#: servers/rendering/shader_language.cpp
msgid "Cannot combine symbols from different sets in expression '.%s'."
msgstr ""
"Không thể kết hợp các biểu tượng từ các tập hợp khác nhau trong biểu thức '."
"%s'."

#: servers/rendering/shader_language.cpp
msgid "Invalid member for '%s' expression: '.%s'."
msgstr "Thành viên không hợp lệ cho biểu thực '%s': '.%s'."

#: servers/rendering/shader_language.cpp
msgid "An object of type '%s' can't be indexed."
msgstr "Đối tượng kiểu '%s' không thể truy xuất chỉ số."

#: servers/rendering/shader_language.cpp
msgid "Invalid base type for increment/decrement operator."
msgstr "Kiểu cơ sở không hợp lệ cho toán tử tăng/giảm."

#: servers/rendering/shader_language.cpp
msgid "Invalid token for the operator: '%s'."
msgstr "Token không hợp lệ cho toán tử: '%s'."

#: servers/rendering/shader_language.cpp
msgid "Unexpected end of expression."
msgstr "Phần đuôi của biểu thức không thể ngờ tới."

#: servers/rendering/shader_language.cpp
msgid "Invalid arguments to unary operator '%s': %s."
msgstr "Đối số không hợp lệ cho toán tử đơn '%s': %s."

#: servers/rendering/shader_language.cpp
msgid "Missing matching ':' for select operator."
msgstr "Thiếu ký tự ':' tương ứng cho toán tử lựa chọn."

#: servers/rendering/shader_language.cpp
msgid "Invalid argument to ternary operator: '%s'."
msgstr "Đối số không hợp lệ cho toán tử ba ngôi: '%s'."

#: servers/rendering/shader_language.cpp
msgid "Invalid arguments to operator '%s': '%s'."
msgstr "Đối số không hợp lệ cho toán tử '%s': '%s'."

#: servers/rendering/shader_language.cpp
msgid "A switch may only contain '%s' and '%s' blocks."
msgstr "Một cấu trúc switch chỉ có thể chứa các khối '%s' và '%s'."

#: servers/rendering/shader_language.cpp
msgid "Expected variable type after precision modifier."
msgstr "Mong đợi kiểu biến sau bổ từ độ chính xác (precision modifier)."

#: servers/rendering/shader_language.cpp
msgid "Invalid variable type (samplers are not allowed)."
msgstr "Kiểu biến không hợp lệ (không cho phép sử dụng sampler)."

#: servers/rendering/shader_language.cpp
msgid "Expected an identifier or '[' after type."
msgstr "Mong đợi một định danh hoặc '[' sau kiểu dữ liệu."

#: servers/rendering/shader_language.cpp
msgid "Expected an identifier."
msgstr "Mong đợi một định danh."

#: servers/rendering/shader_language.cpp
msgid "Expected array initializer."
msgstr "Mong đợi trình khởi tạo mảng."

#: servers/rendering/shader_language.cpp
msgid "Expected data type after precision modifier."
msgstr "Mong đợi kiểu dữ liệu sau bổ từ độ chính xác."

#: servers/rendering/shader_language.cpp
msgid "Expected a constant expression."
msgstr "Mong đợi một biểu thức hằng."

#: servers/rendering/shader_language.cpp
msgid "Expected initialization of constant."
msgstr "Mong đợi khởi tạo hằng số."

#: servers/rendering/shader_language.cpp
msgid ""
"Expected constant expression for argument %d of function call after '='."
msgstr "Mong đợi biểu thức hằng cho đối số %d của hàm sau dấu '='."

#: servers/rendering/shader_language.cpp
msgid "Expected a boolean expression."
msgstr "Mong đợi một biểu thức logic (boolean)."

#: servers/rendering/shader_language.cpp
msgid "Expected an integer or unsigned integer expression."
msgstr "Mong đợi một biểu thức số nguyên hoặc số nguyên không dấu."

#: servers/rendering/shader_language.cpp
msgid "Default case must be defined only once."
msgstr "Trường hợp 'default' chỉ được định nghĩa một lần."

#: servers/rendering/shader_language.cpp
msgid "'%s' must be placed within a '%s' block."
msgstr "'%s' phải được đặt bên trong khối '%s'."

#: servers/rendering/shader_language.cpp
msgid "Undefined identifier '%s' in a case label."
msgstr "Định danh '%s' không xác định trong nhãn case."

#: servers/rendering/shader_language.cpp
msgid "Expected an unsigned integer constant."
