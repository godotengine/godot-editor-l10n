msgstr ""
"Varying có kiểu dữ liệu số nguyên phải được khai báo với bổ từ nội suy `%s`."

#: servers/rendering/shader_language.cpp
msgid "Too many varyings used in shader (%d used, maximum supported is %d)."
msgstr ""
