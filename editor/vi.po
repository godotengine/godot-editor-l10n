msgid "Hint '%s' should be preceded by '%s'."
msgstr "Gợi ý '%s' nên được đặt sau '%s'."

#: servers/rendering/shader_language.cpp
msgid "Range hint is for '%s' and '%s' only."
msgstr "Gợi ý khoảng (range) chỉ dành cho '%s' và '%s'."

#: servers/rendering/shader_language.cpp
msgid "Expected a valid numeric expression."
msgstr "Mong đợi một biểu thức số hợp lệ."

#: servers/rendering/shader_language.cpp
msgid "Expected a valid numeric expression after ','."
msgstr "Mong đợi một biểu thức số hợp lệ sau dấu ','."

