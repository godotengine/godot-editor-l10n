msgid "OpenGL backend (if disabled, the RenderingDevice backend is required)."
msgstr ""
"Backend đồ họa OpenGL (nếu tắt, hệ thống bắt buộc phải sử dụng backend đồ "
"họa thuộc RenderingDevice)."

