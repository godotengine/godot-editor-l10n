msgstr "Giữ phím Shift để tạo các ô gạch lớn."

#: editor/scene/2d/tiles/tile_set_atlas_source_editor.cpp
msgid "Hold Shift to select multiple regions."
msgstr "Giữ phím Shift để chọn nhiều vùng cùng lúc."

#: editor/scene/2d/tiles/tile_set_atlas_source_editor.cpp
