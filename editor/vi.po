msgstr "Cộng hai ma trận biến đổi."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Divides two transforms."
msgstr "Chia hai ma trận biến đổi."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Multiplies two transforms."
msgstr "Nhân hai ma trận biến đổi."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
