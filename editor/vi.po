#: platform/macos/export/export_plugin.cpp
msgid ""
"Code signing: rcodesign path is not set. Configure rcodesign path in the "
"Editor Settings (Export > macOS > rcodesign)."
msgstr ""
"Ký mã nguồn: Chưa đặt đường dẫn rcodesign. Vui lòng cấu hình trong Cài đặt "
"Trình biên tập (Export > macOS > rcodesign)."

#: platform/macos/export/export_plugin.cpp
msgid "Run on remote macOS system"
msgstr "Chạy trên hệ thống macOS từ xa"

#: platform/macos/export/export_plugin.cpp
msgid "Run exported project on remote macOS system"
msgstr "Chạy dự án đã xuất trên hệ thống macOS từ xa"

#: platform/web/export/export_plugin.cpp
msgid "Could not open template for export: \"%s\"."
msgstr "Không thể mở bản mẫu để xuất: \"%s\"."

#: platform/web/export/export_plugin.cpp
msgid "Invalid export template: \"%s\"."
msgstr "Bản mẫu để xuất không hợp lệ: \"%s\"."

#: platform/web/export/export_plugin.cpp
msgid "Could not write file: \"%s\"."
msgstr "Không thể viết tệp tin: \"%s\"."

