msgstr ""
"TileSet đang ở chế độ chỉ đọc. Hãy đặt tài nguyên này thành duy nhất (make "
"unique) để chỉnh sửa các thuộc tính của TileSet."

#: editor/scene/2d/tiles/tile_set_atlas_source_editor.cpp
msgid "Paint properties."
msgstr "Tô vẽ thuộc tính."

#: editor/scene/2d/tiles/tile_set_atlas_source_editor.cpp
