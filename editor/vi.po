msgstr ""
"Thực hiện tra cứu kết cấu theo phương pháp nội suy bậc ba (cubic texture "
"lookup)."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Perform the curve texture lookup."
msgstr "Thực hiện tra cứu kết cấu dựa trên một đường cong (curve)."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Perform the three components curve texture lookup."
msgstr ""
"Thực hiện tra cứu kết cấu dựa trên một đường cong gồm ba thành phần (XYZ/"
"RGB)."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid ""
"Returns the depth value obtained from the depth prepass in a linear space."
msgstr ""
"Trả về giá trị độ sâu nhận được từ giai đoạn tính toán trước độ sâu (depth "
"prepass) trong không gian tuyến tính."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Reconstructs the World Position of the Node from the depth texture."
msgstr ""
"Tái cấu trúc lại Tọa độ Thế giới (World Position) của Node dựa trên kết cấu "
"bản đồ độ sâu (depth texture)."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Unpacks the Screen Normal Texture in World Space"
msgstr ""
"Giải nén kết cấu vectơ pháp tuyến màn hình (Screen Normal Texture) sang "
"Không gian Thế giới"

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Perform the 2D texture lookup."
msgstr "Thực hiện tra cứu kết cấu bề mặt 2D."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Perform the 2D-array texture lookup."
msgstr "Thực hiện tra cứu mảng kết cấu bề mặt 2D (2D-array)."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Perform the 3D texture lookup."
msgstr "Thực hiện tra cứu kết cấu bề mặt 3D."

