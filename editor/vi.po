msgstr "Chuyển đổi tọa độ màn hình UV sang không gian dữ liệu SDF."

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "Casts a ray against the screen SDF and returns the distance travelled."
msgstr ""
"Đổ một tia dò (raycast) vào trường khoảng cách ký hiệu của màn hình (screen "
