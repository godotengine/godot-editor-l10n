#: editor/project_manager/project_manager.cpp
msgctxt "Application"
msgid "Project Manager"
msgstr "Trình quản lý dự án"

#: editor/project_manager/project_manager.cpp
msgid "You don't have any projects yet."
msgstr "Bạn chưa có dự án nào cả."

#: editor/project_manager/project_manager.cpp
msgid ""
"Get started by creating a new one,\n"
"importing one that exists, or by downloading a project template from the "
"Asset Store!"
msgstr ""
"Hãy bắt đầu bằng cách tạo một dự án mới,\n"
"nhập một dự án sẵn có, hoặc tải xuống một bản mẫu dự án từ Asset Store!"

