msgstr "Tạo các ô gạch"

#: editor/scene/2d/tiles/tile_set_atlas_source_editor.cpp
msgid "Create a tile"
msgstr "Tạo một ô gạch"

#: editor/scene/2d/tiles/tile_set_atlas_source_editor.cpp
