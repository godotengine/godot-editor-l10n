msgid "Stencil mode reference value cannot be greater than 255: '%s'."
msgstr "Giá trị tham chiếu chế độ stencil không được lớn hơn 255: '%s'."

#: servers/rendering/shader_language.cpp
msgid "Expected a struct identifier."
msgstr "Mong đợi một định danh struct."

#: servers/rendering/shader_language.cpp
msgid "Nested structs are not allowed."
msgstr "Không cho phép cấu trúc struct lồng nhau."

#: servers/rendering/shader_language.cpp
msgid "Expected data type."
msgstr "Mong đợi kiểu dữ liệu."

#: servers/rendering/shader_language.cpp
msgid "A '%s' data type is not allowed here."
msgstr "Kiểu dữ liệu '%s' không được phép sử dụng ở đây."

