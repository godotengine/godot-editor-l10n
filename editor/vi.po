msgstr ""
"'hint_normal_roughness_texture' chỉ khả dụng khi sử dụng trình kết xuất "
"Forward+."

#: servers/rendering/shader_language.cpp
msgid "'hint_normal_roughness_texture' is not supported in '%s' shaders."
msgstr ""
"'hint_normal_roughness_texture' không được hỗ trợ trong shader kiểu '%s'."

#: servers/rendering/shader_language.cpp
msgid "'hint_depth_texture' is not supported in '%s' shaders."
msgstr "'hint_depth_texture' không được hỗ trợ trong shader kiểu '%s'."

#: servers/rendering/shader_language.cpp
msgid "'hint_blit_source' is not supported in '%s' shaders."
msgstr "'hint_blit_source' không được hỗ trợ trong shader kiểu '%s'."

#: servers/rendering/shader_language.cpp
msgid "This hint is only for sampler types."
msgstr "Gợi ý này chỉ dành cho các kiểu sampler."

#: servers/rendering/shader_language.cpp
