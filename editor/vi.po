msgid "The '%s' data type is not allowed here."
msgstr "Kiểu dữ liệu '%s' không được cho phép tại đây."

#: servers/rendering/shader_language.cpp
msgid "Interpolation modifier '%s' cannot be used with boolean types."
msgstr "Bổ từ nội suy '%s' không thể được sử dụng với kiểu dữ liệu boolean."

#: servers/rendering/shader_language.cpp
msgid "Invalid data type for varying."
msgstr "Kiểu dữ liệu không hợp lệ cho varying."

