msgstr ""
"Định nghĩa lại chế độ stencil: '%s'. Chế độ '%s' đã được thiết lập là '%s'."

#: servers/rendering/shader_language.cpp
msgid ""
"Redefinition of render mode: '%s'. The '%s' mode has already been set to "
