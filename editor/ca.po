msgid "1.0 - vector"
msgstr "1.0 - vector"

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid "1.0 / vector"
msgstr "1.0 / vector"

#: modules/visual_shader/editor/visual_shader_editor_plugin.cpp
msgid ""
"Returns the vector that points in the direction of reflection ( a : incident "
